# =====================================================
# AlgoVault Environment Variables
# =====================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Supabase (used as DATABASE only, NOT for auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# SMTP Configuration (Gmail with App Password)
# How to get Gmail App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Factor Authentication
# 3. Go to App Passwords → Generate one for "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_16_char_app_password
SMTP_FROM=AlgoVault <your_email@gmail.com>

# JWT Secret (generate a random 64-character string)
# You can generate one at: https://generate-secret.vercel.app/64
JWT_SECRET=generate_a_random_64_char_string_here

# OnlineCompiler.io API
# Sign up at https://api.onlinecompiler.io to get your API key
ONLINE_COMPILER_API_KEY=your_onlinecompiler_api_key_here

# App URL
# Local: http://localhost:3000
# Production: Your Vercel deploy URL (e.g. https://algo-vault-seven.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
